HYDRA_X_PUBLIC_URL=http://localhost:4000
HYDRA_X_SECRET_KEY=replace-with-a-long-random-secret
# Optional: reference runtime secrets from saved configs with values like env:HYDRA_X_OPENAI_API_KEY
HYDRA_X_WORKSPACE_ROOT=./workspace
HYDRA_X_BACKUP_ROOT=./backups
HYDRA_X_INSTALL_ROOT=./install
HYDRA_X_COALESCE_WINDOW_MS=250
HYDRA_X_CORTEX_INTERVAL_MS=60000
HYDRA_X_SCHEDULER_POLL_MS=15000
HYDRA_X_SHELL_ALLOWLIST=pwd,ls,cat,head,rg,git
HYDRA_X_HTTP_ALLOWLIST=
HYDRA_X_EMBEDDING_BACKEND=local_hash_v1
# HYDRA_X_EMBEDDING_URL=https://api.openai.com/v1/embeddings
# HYDRA_X_EMBEDDING_API_KEY=replace-me
# HYDRA_X_EMBEDDING_MODEL=text-embedding-3-small
