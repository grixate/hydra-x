#!/usr/bin/env bash
set -euo pipefail

command="${1:-}"

if [[ -z "${command}" ]]; then
  echo "Usage: ./hydra_x <new|serve|chat|migrate|healthcheck|telegram-webhook|provider-test|jobs|backup> [args...]"
  exit 1
fi

shift

case "${command}" in
  new) exec mix hydra_x.new "$@" ;;
  serve) exec mix hydra_x.serve "$@" ;;
  chat) exec mix hydra_x.chat "$@" ;;
  migrate) exec mix hydra_x.migrate "$@" ;;
  healthcheck) exec mix hydra_x.healthcheck "$@" ;;
  telegram-webhook) exec mix hydra_x.telegram.webhook "$@" ;;
  provider-test) exec mix hydra_x.providers.test "$@" ;;
  jobs) exec mix hydra_x.jobs "$@" ;;
  backup) exec mix hydra_x.backup "$@" ;;
  *)
    echo "Unknown command: ${command}"
    exit 1
    ;;
esac
